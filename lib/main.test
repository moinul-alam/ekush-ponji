import 'package:flutter/material.dart';
import 'package:flutter/services.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:hive_flutter/hive_flutter.dart';
import 'app/app.dart';
// import 'app/config/app_config.dart';

void main() async {
  // Ensure Flutter binding is initialized
  WidgetsFlutterBinding.ensureInitialized();

  // Initialize services
  await _initializeApp();

  // Run the app
  runApp(
    const ProviderScope(
      child: EkushPonjiApp(),
    ),
  );
}

/// Initialize all app services and configurations
Future<void> _initializeApp() async {
  try {
    // Set preferred orientations
    await SystemChrome.setPreferredOrientations([
      DeviceOrientation.portraitUp,
      DeviceOrientation.portraitDown,
    ]);

    // Set system UI overlay style
    SystemChrome.setSystemUIOverlayStyle(
      const SystemUiOverlayStyle(
        statusBarColor: Colors.transparent,
        statusBarIconBrightness: Brightness.dark,
        systemNavigationBarColor: Colors.white,
        systemNavigationBarIconBrightness: Brightness.dark,
      ),
    );

    // Initialize Hive
    await _initializeHive();

    // TODO: Initialize Firebase
    // await Firebase.initializeApp(
    //   options: DefaultFirebaseOptions.currentPlatform,
    // );

    // TODO: Initialize Notifications
    // await _initializeNotifications();

    // TODO: Initialize other services
    // - Analytics
    // - Crash Reporting
    // - Remote Config

    debugPrint('✅ App initialization completed successfully');
  } catch (e, stackTrace) {
    debugPrint('❌ App initialization failed: $e');
    debugPrint('StackTrace: $stackTrace');
    // App will still run but some features might not work
  }
}

/// Initialize Hive local database
Future<void> _initializeHive() async {
  try {
    await Hive.initFlutter();

    // TODO: Register Hive adapters here
    // Example:
    // Hive.registerAdapter(UserSettingsAdapter());
    // Hive.registerAdapter(ReminderAdapter());
    // Hive.registerAdapter(CustomEventAdapter());

    // TODO: Open Hive boxes
    // await Hive.openBox('settings');
    // await Hive.openBox('reminders');
    // await Hive.openBox('events');

    debugPrint('✅ Hive initialized successfully');
  } catch (e, stackTrace) {
    debugPrint('❌ Hive initialization failed: $e');
    debugPrint('StackTrace: $stackTrace');
    rethrow;
  }
}

